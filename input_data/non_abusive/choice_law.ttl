@prefix : <http://example.com/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix tosl: <https://w3id.org/tosl/> .
@base <http://example.com> .

:Agreement a odrl:Agreement ;
    dcterms:title "Agreement with litigation process governed by consumer's country law" ;
    tosl:onDispute :ChoiceLawLitigation ;
    :policyGraph {
        :ChoiceLawLitigation a tosl:Litigation;
            dcterms:description "This Agreement will be governed by the laws of the consumer's country, and the parties consent to the exclusive jurisdiction of its courts for any related actions.";    
            tosl:targetParty :customer ;
            tosl:takesPlaceIn tosl:consumerPlaceCourts ;
            tosl:governedBy tosl:consumerPlaceLaw .

        :customer a tosl:Customer .
    } .