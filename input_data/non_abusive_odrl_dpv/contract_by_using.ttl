@prefix : <http://example.com/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix dpv-odrl: <https://w3id.org/dpv/mappings/odrl#> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix pd: <https://w3id.org/dpv/pd#> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix justifications: <https://w3id.org/dpv/justifications#> .
@prefix tosl: <https://w3id.org/tosl/> .
@base <http://example.com> .


:Agreement a odrl:Agreement ;
    dcterms:title "Agreement without explicit consent requirement" ;
    odrl:profile dpv-odrl: ;
    :policyGraph {
        :DutyExplicitConsent a odrl:Permission ;
            dcterms:description "You agree to these terms by providing explicit consent";
            odrl:assigner :provider ; # an odrl:Agreement needs to have an odrl:assigner
            odrl:assignee :customer ;
            odrl:action dpv-odrl:Use ;
            odrl:target :service ;
            odrl:constraint [
                    a odrl:Constraint;
                    odrl:leftOperand dpv-odrl:LegalBasis ;
                    odrl:operator odrl:eq ;
                    odrl:rightOperand dpv:ExplicitlyExpressedConsent 
            ] .
            
        :provider a dpv-odrl:ServiceProvider .
        :customer a dpv-odrl:Customer .
        :service a tosl:Service .
    } .
