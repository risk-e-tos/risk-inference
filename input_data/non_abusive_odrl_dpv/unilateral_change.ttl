@prefix : <http://example.com/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix dpv-odrl: <https://w3id.org/dpv/mappings/odrl#> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix pd: <https://w3id.org/dpv/pd#> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix justifications: <https://w3id.org/dpv/justifications#> .
@prefix tosl: <https://w3id.org/tosl/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.com> .

:Agreement a odrl:Agreement ;
    dcterms:title "Agreement with a pricing modification term" ;
    odrl:profile dpv-odrl: ;
    :policyGraph {
        :permissionChangePricing a odrl:Permission ;
            dcterms:description "Provider may change prices from time to time.";
            odrl:assigner :customer ; # an odrl:Agreement needs to have an odrl:assigner
            odrl:assignee :provider ;
            odrl:action :changePrice;
            odrl:target :service ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand odrl:delayPeriod ;
                odrl:operator odrl:gteq ;
                odrl:rightOperand "P30D"^^xsd:duration
            ] ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand dpv-odrl:Justification ; # or dpv:Justification
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand (
                    justifications:LegalObligation # ServiceUpdate and ImproveFeatures dpv:ImproveExistingProductsAndServices a dpv:Purpose
                )
            ] ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand dpv-odrl:ConsentControl ;
                odrl:operator odrl:eq ;
                odrl:rightOperand dpv:ReaffirmConsent
            ] ;
            odrl:duty [
                a odrl:Duty ;
                odrl:action odrl:inform ;
                odrl:assignee :provider ;
                # odrl:target :pricing ; not needed 
                odrl:informedParty :customer ;
                odrl:constraint [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:deliveryChannel ;
                    odrl:operator odrl:isA ;
                    odrl:rightOperand :customerContact
                ] ;
                # should there be a purpose constraint like the one in content removal?
            ] .   
        
        :provider a dpv-odrl:ServiceProvider .
        :customer a dpv-odrl:Customer .
        :changePrice a odrl:Action ;
            odrl:includedIn odrl:use .
        :service a tosl:Service .
        :customerContact a pd:Contact .
    } .
