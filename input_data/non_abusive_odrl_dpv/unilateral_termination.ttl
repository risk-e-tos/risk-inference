@prefix : <http://example.com/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix dpv-odrl: <https://w3id.org/dpv/mappings/odrl#> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix pd: <https://w3id.org/dpv/pd#> .
@prefix loc: <https://w3id.org/dpv/loc#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix justifications: <https://w3id.org/dpv/justifications#> .
@prefix tosl: <https://w3id.org/tosl/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@base <http://example.com> .

:Agreement a odrl:Agreement ;
    dcterms:title "Agreement with an agreement termination term" ;
    odrl:profile dpv-odrl: ;
    :policyGraph {
        :permissionTerminateTerms a odrl:Permission ;
            dcterms:description "Provider can terminate the agreement at their discretion";
            odrl:assigner :customer ; # an odrl:Agreement needs to have an odrl:assigner
            odrl:assignee :provider ;
            odrl:action tosl:terminate ;
            odrl:target :service ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand odrl:delayPeriod ;
                odrl:operator odrl:gteq ;
                odrl:rightOperand "P30D"^^xsd:duration
            ] ;
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand dpv-odrl:Justification ; # or dpv:Justification
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand (
                    justifications:SecurityImpaired
                    justifications:UnlawfulActivityObjection
                    justifications:LegalObligation
                )
            ] ;
            odrl:duty [
                a odrl:Duty ;
                odrl:assignee :provider ;
                odrl:action odrl:inform ;
                # odrl:target :agreement ; not needed
                odrl:informedParty :customer ;
                odrl:constraint [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:deliveryChannel ;
                    odrl:operator odrl:isA ;
                    odrl:rightOperand :customerContact
                ]
            ] ;
             odrl:duty [
                a odrl:Duty ;
                odrl:assignee :provider ;
                odrl:action odrl:compensate ; # should the action have a refinement where the payment amount is specified like the example in https://www.w3.org/TR/odrl-model/#duty-perm
                # odrl:target :agreement ; not needed
                odrl:compensatedParty :customer ;
            ] .
            
        :provider a dpv-odrl:ServiceProvider .
        :customer a dpv-odrl:Customer .
        :service a tosl:Service .
        :customerContact a pd:Contact .
    } .