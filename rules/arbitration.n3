  
@prefix : <http://example.com/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix tosl: <https://w3id.org/tosl/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix risk: <https://w3id.org/dpv/risk#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix new: <http://example.com/new#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

{
    ?agreement :policyGraph ?G .

    ?G log:includes {
        ?arbitration a tosl:Arbitration .
    } .

    ?G log:notIncludes {
        ?litigation a tosl:Litigation ;
            tosl:requires ?arbitration .
    } .

    ( "Risk: disputes must be resolved exclusively through arbitration, with no access to litigation, and under a jurisdiction and governing law that are not those of the consumer. Dispute resolution method: %s"
        ?arbitration ) string:format ?why .

    ( ?agreement :UnfairContractClause ?arbitration ) log:skolem ?src .
    ( ?agreement :RiskArbitration ?arbitration ) log:skolem ?risk .
}
=>
{

    ?src a new:ArbitrationClause ;
        dpv:hasContractualClause ?arbitration .

    ?risk a dpv:Risk ;
        skos:broader risk:RightsDenied, risk:RightsLimited, risk:RightsObstructed ;
        dpv:hasRiskSource ?src ;
        dct:description ?why .

    ?risk dpv:hasConsequence [
        a risk:InabilityToEstablishLegalClaims, risk:LegalSupportLimited, risk:RightsExercisePrevented ;
        dpv:hasImpact risk:JudicialCosts ;
        dpv:isMitigatedByMeasure new:AccessToCourts, new:ConsumerResidenceJurisdiction, new:ConsumerCountryGoverningLaw
    ] .

    new:AccessToCourts a dpv:RiskMitigationMeasure ;
        :suggestAdd {
           :litigation a tosl:Litigation ;
                tosl:targetParty :customer ;
                tosl:requires ?arbitration .
        } .

    new:ConsumerResidenceJurisdiction a dpv:RiskMitigationMeasure ;
        :suggestAdd {
            :litigation tosl:takesPlaceIn tosl:consumerPlaceCourts .
        } .

    new:ConsumerCountryGoverningLaw a dpv:RiskMitigationMeasure ;
        :suggestAdd {
            :litigation tosl:governedBy tosl:consumerPlaceLaw .
        } .

    ?risk log:outputString ?why .

} .