@prefix : <http://example.com/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix tosl: <https://w3id.org/tosl/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix risk: <https://w3id.org/dpv/risk#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix new: <http://example.com/new#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

{
    ?agreement :policyGraph ?G .

    ?G log:includes {
        ?perm a odrl:Permission ;
        odrl:assignee ?p ;
        odrl:action tosl:remove ;
        odrl:target ?a .

        ?p a tosl:Provider .
        ?a a tosl:UserContent .
    } .

    ?G log:notIncludes {
        ?perm odrl:constraint [
            odrl:leftOperand odrl:delayPeriod
        ] .
    } .

    ?G log:notIncludes {
        ?perm odrl:constraint [
        odrl:leftOperand tosl:justification
        ] .
    } .

    ?G log:notIncludes {
        ?perm odrl:duty [
        odrl:action odrl:inform
        ] .
    } .

    ( "Risk: data removal is permitted without restrictions (no justification constraint, no prior notice constraint, and no duty to inform). Permission: %s"
        ?perm ) string:format ?why .

    ( ?agreement :UnfairContractClause ?perm ) log:skolem ?src .
    ( ?agreement :RiskDataDeletion ?perm ) log:skolem ?risk .

}
=>
{

    ?perm a dpv:Permission .

    ?src a new:ContentRemovalClause ;
        dpv:hasContractualClause ?perm .

    ?risk a dpv:Risk ;
        skos:broader risk:DataUnavailable, risk:ServiceTermination ;
        dpv:hasRiskSource ?src ;
        dct:description ?why .

    ?risk dpv:hasConsequence [
        a risk:DataLoss, risk:ServiceNotProvided ;
        dpv:hasImpact risk:FinancialLoss, risk:NonMaterialDamage, risk:CustomerConfidenceLoss ;
        dpv:isMitigatedByMeasure new:DeletionNotice, new:ProvideJustification
    ] .

    new:DeletionNotice a dpv:OrganisationalMeasure, dpv:RiskMitigationMeasure ;
        skos:broader dpv:Notice ;
        :suggestAdd {
            ?perm 
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand odrl:delayPeriod ;
                odrl:operator odrl:gteq ;
                odrl:rightOperand "P30D"^^xsd:duration
            ] ;
            odrl:duty [
                a odrl:Duty ;
                odrl:assignee :provider ;
                odrl:action odrl:inform ;
                odrl:target :userData ;
                odrl:informedParty :customer ;
                odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand odrl:deliveryChannel ;
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand ( "email"^^xsd:string "inProductNotification"^^xsd:string )
                ]
            ] .
        } .

    new:ProvideJustification a dpv:RiskMitigationMeasure ;
        :suggestAdd {
            ?perm 
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand tosl:justification ;
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand ( "termviolation" "serviceprotection" "fraudprevention" )
            ] .
        } .

    ?risk log:outputString ?why .

} .