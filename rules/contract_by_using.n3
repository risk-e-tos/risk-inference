@prefix : <http://example.com/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix tosl: <https://w3id.org/tosl/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix risk: <https://w3id.org/dpv/risk#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix new: <http://example.com/new#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

{
  ?agreement :policyGraph ?G .

    ?G log:includes {
        ?duty a odrl:Duty ;
        odrl:assignee ?c ;
        odrl:action tosl:consent ;
        odrl:target ?a .

        ?c a tosl:Customer .
    } .

    ?G log:notIncludes {
        ?perm odrl:constraint [
            odrl:leftOperand tosl:consentType ;
            odrl:operator odrl:eq ;
            odrl:rightOperand tosl:explicitConsent
        ] .
    } .

    ( "Risk: acceptance of the Terms is inferred from mere use of the service (no explicit consent constraint). Duty: %s"
        ?duty ) string:format ?why .

    ( ?agreement :UnfairContractClause ?duty ) log:skolem ?src .
    ( ?agreement :RiskContractByUsing ?duty ) log:skolem ?risk .

}
=>
{

    ?duty a dpv:Obligation .

    ?src a new:ContractByUsingClause ;
        dpv:hasContractualClause ?duty .

    ?risk a dpv:Risk ;
        skos:broader risk:RightsLimited, risk:RightsObstructed  ;
        dpv:hasRiskSource ?src ;
        dct:description ?why .

    ?risk dpv:hasConsequence [
        a risk:QualityDegraded ;
        dpv:hasImpact risk:FinancialLoss, risk:NonMaterialDamage, risk:CustomerConfidenceLoss ;
        dpv:isMitigatedByMeasure new:ExplicitConsentRequirement
    ] .

    new:ExplicitConsentRequirement a dpv:RiskMitigationMeasure ;
        skos:broader dpv:Consent ;
        :suggestAdd {
            ?duty
            odrl:constraint [
                a odrl:Constraint;
                odrl:leftOperand tosl:consentType ;
                odrl:operator odrl:eq ;
                odrl:rightOperand tosl:explicitConsent
            ] .
        } .

    ?risk log:outputString ?why .

} .