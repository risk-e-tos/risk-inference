@prefix : <http://example.com/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix odrl: <http://www.w3.org/ns/odrl/2/> .
@prefix tosl: <https://w3id.org/tosl/> .
@prefix log: <http://www.w3.org/2000/10/swap/log#> .
@prefix string: <http://www.w3.org/2000/10/swap/string#> .
@prefix dpv: <https://w3id.org/dpv#> .
@prefix risk: <https://w3id.org/dpv/risk#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix new: <http://example.com/new#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

{
    ?agreement :policyGraph ?G .

    ?G log:includes {
        ?perm a odrl:Permission ;
        odrl:assignee ?p ;
        odrl:action odrl:modify ;
        odrl:target ?a .

        ?p a tosl:Provider .
    } .

    ?G log:notIncludes {
        ?perm odrl:constraint [
            odrl:leftOperand odrl:delayPeriod
        ] .
    } .

    ?G log:notIncludes {
        ?perm odrl:constraint [
            odrl:leftOperand tosl:justification
        ] .
    } .

    ?G log:notIncludes {
        ?perm odrl:duty [
            odrl:action odrl:inform
        ] .
    } .

    ?G log:notIncludes {
        ?perm odrl:constraint[
            odrl:leftOperand tosl:consentType;
            odrl:operator odrl:eq ;
            odrl:rightOperand tosl:implicitConsent
        ] .
    } .

    ( "Risk: agreement or services change is permitted without restrictions (no justification constraint, no prior notice constraint, no duty to inform and not reaffirm consent). Permission: %s"
        ?perm ) string:format ?why .

    ( ?agreement :UnfairContractClause ?perm ) log:skolem ?src .
    ( ?agreement :RiskAgreementOrServicesChange ?perm ) log:skolem ?risk .

    ( ?risk :MitigationDelayPeriod ?perm ) log:skolem ?mDelay .
    ( ?risk :MitigationJustification ?perm ) log:skolem ?mJust .
    ( ?risk :MitigationDutyToInform ?perm ) log:skolem ?mInform .
    ( ?risk :MitigationExplicitConsent ?perm ) log:skolem ?mConsent .

}
=>
{

    ?perm a dpv:Permission .

    ?src a new:UnilateralChangeClause ;
    dpv:hasContractualClause ?perm .

    ?risk a dpv:Risk ;
        skos:broader risk:Harm, risk:ServiceCostIncreased, risk:ServicePartiallyProvided  ;
        dpv:hasRiskSource ?src ;
        dct:description ?why .

    ?risk dpv:hasConsequence [
        a risk:QualityDegraded, risk:ServiceQualityReduced, risk:ServiceProvisionDelayed, risk:ServiceNotProvided ;
        dpv:hasImpact risk:FinancialLoss, risk:NonMaterialDamage, risk:CustomerConfidenceLoss ;
        dpv:isMitigatedByMeasure new:ChangeNotice, new:ProvideJustification, new:ReaffirmConsent
    ] .

    new:ChangeNotice a dpv:OrganisationalMeasure, dpv:RiskMitigationMeasure ;
        skos:broader dpv:Notice ;
        :suggestAdd {
            ?perm 
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand odrl:delayPeriod ;
                odrl:operator odrl:gteq ;
                odrl:rightOperand "P30D"^^xsd:duration
            ] ;
            odrl:duty [
                a odrl:Duty ;
                odrl:assignee :provider ;
                odrl:action odrl:inform ;
                odrl:target :pricing ;
                odrl:informedParty :customer ;
                odrl:constraint [
                    a odrl:Constraint ;
                    odrl:leftOperand odrl:deliveryChannel ;
                    odrl:operator odrl:isAnyOf ;
                    odrl:rightOperand ( "email"^^xsd:string "inProductNotification"^^xsd:string )
                ]
            ] .
        } .

    new:ReaffirmConsent a dpv:RiskMitigationMeasure ;
        :suggestAdd {
            ?perm 
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand tosl:consentType;
                odrl:operator odrl:eq ;
                odrl:rightOperand tosl:explicitConsent
            ] .
        } .

    new:ProvideJustification a dpv:RiskMitigationMeasure ;
        :suggestAdd {
            ?perm 
            odrl:constraint [
                a odrl:Constraint ;
                odrl:leftOperand tosl:justification ;
                odrl:operator odrl:isAnyOf ;
                odrl:rightOperand ( "lawchange" "update" )
            ] .
        } .

    ?risk log:outputString ?why .
} .